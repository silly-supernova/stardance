#!/usr/bin/env ruby
require "fileutils"

# Re-exec under the project's mise-managed toolchain. This file's shebang picks
# up whatever `ruby` is first on PATH (often the system Ruby), and recent mise
# does NOT auto-activate from .ruby-version, so without this the wrong Ruby/Node
# would run bundle/yarn/rails. Guarded so it happens once, and only when mise is
# installed (CI / non-mise contributors fall through to their own toolchain).
if ENV["STARDANCE_TOOLCHAIN"].nil? && system("command -v mise > /dev/null 2>&1")
  root = File.expand_path("..", __dir__)
  rv = (File.read(File.join(root, ".ruby-version")).strip.sub(/\Aruby-/, "") rescue "3.4.3")
  nv = (File.read(File.join(root, ".node-version")).strip rescue "22")
  exec({ "STARDANCE_TOOLCHAIN" => "1" }, "mise", "exec", "ruby@#{rv}", "node@#{nv}", "--", "ruby", __FILE__, *ARGV)
end

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

# Load this worktree's deterministic ports + DATABASE_URL (see bin/worktree-env.sh).
def worktree_env
  env = {}
  `sh #{File.join(__dir__, "worktree-env.sh")} --print`.each_line do |line|
    key, _, value = line.strip.partition("=")
    env[key] = value unless key.empty?
  end
  env
end

# Point .env's DATABASE_URL at this worktree's own db container (native Rails
# reaches the Dockerized Postgres on localhost:DB_PORT, not the compose-only
# "db" hostname). Idempotent: rewrites the line if present, appends otherwise.
def ensure_database_url!(url)
  lines = File.exist?(".env") ? File.readlines(".env") : []
  replaced = false
  lines.map! do |line|
    if line =~ /\A\s*DATABASE_URL\s*=/
      replaced = true
      "DATABASE_URL=#{url}\n"
    else
      line
    end
  end
  lines << "DATABASE_URL=#{url}\n" unless replaced
  File.write(".env", lines.join)
end

def wait_for_postgres!
  30.times do
    return if system("docker compose exec -T db pg_isready -U postgres -q")
    sleep 1
  end
  warn "Postgres did not become ready after 30s — continuing anyway."
end

FileUtils.chdir APP_ROOT do
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.
  # Add necessary setup steps to this file.

  puts "== Preparing environment file =="
  unless File.exist?(".env")
    FileUtils.cp "example.env", ".env"
    puts "Copied example.env -> .env (its dev keys work as-is; edit for real secrets)"
  end

  env = worktree_env
  puts "Worktree '#{env['WORKTREE_SLUG']}' -> web :#{env['WEB_PORT']}, db :#{env['DB_PORT']}"
  ENV["DB_PORT"] = env["DB_PORT"] # consumed by docker-compose.yml's db port mapping
  ensure_database_url!(env["DATABASE_URL"])

  puts "\n== Starting database (this worktree's own container on :#{env['DB_PORT']}) =="
  system! "docker compose up -d db"
  wait_for_postgres!

  puts "\n== Installing Ruby dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Installing JavaScript dependencies =="
  # package.json pins Yarn 4 via Corepack. A plain global `yarn` is usually v1 and
  # refuses to install against a packageManager pin. `corepack enable` points
  # `yarn` at the pinned version (also used by `yarn build` in Procfile.dev), and
  # `corepack yarn` runs it whether or not the shim got enabled.
  system("corepack enable")
  system! "corepack yarn install"

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
