<section class="project-outcome">
  <h2 class="project-outcome__title"><span class="project-outcome__title--italic">For example &mdash;</span></h2>
  <p class="project-outcome__subtitle">Here&rsquo;s what this project might get as a prize.</p>

  <div class="project-outcome__stage">
    <div class="project-outcome__col project-outcome__col--project">
      <article class="project-outcome__card project-outcome__card--project">
        <%= image_tag image_url("landing/project-outcome/phthallo-site.png"), class: "project-outcome__card-bg", alt: "phthallo.site portfolio screenshot", loading: "lazy" %>
        <div class="project-outcome__card-fade" aria-hidden="true"></div>
        <div class="project-outcome__card-meta">
          <p class="project-outcome__card-name">Phthallo&rsquo;s site</p>
          <p class="project-outcome__card-hours">27 hours spent</p>
          <p class="project-outcome__card-desc">Personal site/portfolio/blog, built with Astro and Tailwind, hosted on Nest.</p>
        </div>
      </article>
      <div class="project-outcome__meter">
        <%= image_tag image_url("landing/done-before/star-deco-card.svg"), class: "project-outcome__meter-star", alt: "", aria: { hidden: true }, loading: "lazy" %>
        <span class="project-outcome__meter-text">Earns 270 stardust</span>
      </div>
    </div>

    <%= image_tag image_url("landing/project-outcome/arrow.svg"), class: "project-outcome__arrow project-outcome__arrow--desktop", alt: "", aria: { hidden: true }, loading: "lazy" %>
    <%= image_tag image_url("landing/project-outcome/arrow-mobile.svg"), class: "project-outcome__arrow project-outcome__arrow--mobile", alt: "", aria: { hidden: true }, loading: "lazy" %>

    <div class="project-outcome__col">
      <article class="project-outcome__card project-outcome__card--prize">
        <%= image_tag image_url("landing/project-outcome/domain-grant.png"), class: "project-outcome__card-prize-img project-outcome__card-prize-img--domain", alt: "Domain grant", loading: "lazy" %>
        <p class="project-outcome__card-prize-label">Domain grant</p>
      </article>
      <div class="project-outcome__meter">
        <%= image_tag image_url("landing/done-before/star-deco-card.svg"), class: "project-outcome__meter-star", alt: "", aria: { hidden: true }, loading: "lazy" %>
        <span class="project-outcome__meter-text">80 stardust</span>
      </div>
    </div>

    <span class="project-outcome__plus" aria-hidden="true">+</span>

    <div class="project-outcome__col">
      <article class="project-outcome__card project-outcome__card--prize">
        <%= image_tag image_url("landing/project-outcome/raspberry-pi-5.png"), class: "project-outcome__card-prize-img project-outcome__card-prize-img--rpi", alt: "Raspberry Pi 5", loading: "lazy" %>
        <p class="project-outcome__card-prize-label">Raspberry Pi 5</p>
      </article>
      <div class="project-outcome__meter">
        <%= image_tag image_url("landing/done-before/star-deco-card.svg"), class: "project-outcome__meter-star", alt: "", aria: { hidden: true }, loading: "lazy" %>
        <span class="project-outcome__meter-text">190 stardust</span>
      </div>
    </div>
  </div>

  <p class="project-outcome__disclaimer">*Stardust price of items may vary per region.</p>
</section>
