<% content_for :title, "Review: #{@ship.project.title}" %>

<% can_review = @ship.claim_held_by?(current_user) && @ship.pending? %>

<div class="app-layout app-layout--wide"
     data-controller="certification--queue"
     data-certification--queue-server-now-value="<%= Time.current.iso8601 %>">
  <div class="app-layout__main app-layout__main--wide ship-review">
    <%= link_to "← back to queue", admin_certification_ships_path, class: "ship-review__back" %>
    <% if @ship.project.hardware? && Flipper.enabled?(:hardware_flow, current_user) %>
      <%= link_to "Open hardware review →",
            admin_certification_hardware_review_path(@ship.project),
            class: "ship-review__back ship-review__back--alt" %>
    <% end %>

    <div class="ship-review__momentum" role="status" aria-live="polite">
      <% if @reviewed_today.zero? %>
        <span class="ship-review__momentum-label">First review of the day. Let's go. Next multiplier: <strong><%= @next_multiplier %>x</strong> (Estimated rank: <%= @next_rank.ordinalize %>)</span>
      <% else %>
        <span class="ship-review__momentum-count"><%= @reviewed_today %></span>
        <span class="ship-review__momentum-label">reviewed today. Keep the momentum going. Next multiplier: <strong><%= @next_multiplier %>x</strong> (Estimated rank: <%= @next_rank.ordinalize %>)</span>
      <% end %>
    </div>

    <header class="ship-review__header">
      <div class="ship-review__title">
        <h1><%= @ship.project.title %></h1>
        <span class="status-pill status-pill--<%= @ship.status %>"><%= @ship.status.capitalize %></span>
      </div>
      <span class="ship-review__id">#<%= @ship.id %></span>
    </header>

    <div class="ship-review__body">
      <section class="ship-review__details">
        <div class="ship-review__panel">
          <h2 class="ship-review__panel-title">Submission</h2>
          <dl class="ship-review__meta">
            <dt>Submitter</dt>
            <dd><%= @owner&.display_name || "—" %></dd>
            <dt>Submitted</dt>
            <dd><%= time_ago_in_words(@ship.project.shipped_at || @ship.created_at) %> ago</dd>
            <% if @ship.reviewer %>
              <dt>Reviewer</dt>
              <dd><%= @ship.reviewer.display_name %></dd>
            <% end %>
            <dt>Updated project</dt>
            <dd>
              <% if @ship.project.update_description.present? %>
                <span class="ship-review__badge ship-review__badge--yes">Yes</span>
                <p class="ship-review__update-desc"><%= @ship.project.update_description %></p>
              <% else %>
                <span class="ship-review__badge ship-review__badge--no">No</span>
              <% end %>
            </dd>
            <% if @ship.project.description.present? %>
              <dt>Description</dt>
              <dd><%= @ship.project.description %></dd>
            <% end %>
            <dt>AI Declaration</dt>
            <dd>
              <% if @ship.project.ai_declaration.present? %>
                <%= @ship.project.ai_declaration %>
              <% else %>
                <span class="ship-review__no-declaration">None provided.</span>
              <% end %>
            </dd>
            <dt>Links</dt>
            <dd class="ship-review__link-row">
              <%= link_to "project page", project_path(@ship.project), target: "_blank", rel: "noopener" %>
              <% if @ship.project.demo_url.present? %>
                <%= link_to "demo", @ship.project.demo_url, target: "_blank", rel: "noopener" %>
              <% end %>
              <% if @ship.project.repo_url.present? %>
                <%= link_to "repo", @ship.project.repo_url, target: "_blank", rel: "noopener" %>
              <% end %>
              <% if @ship.project.readme_url.present? %>
                <%= link_to "readme", @ship.project.readme_url, target: "_blank", rel: "noopener" %>
              <% end %>
              <a href="<%= project_url(@ship.project) %>"
                 target="_blank" rel="noopener"
                 data-urls="<%= html_escape([project_url(@ship.project), @ship.project.demo_url, @ship.project.repo_url, @ship.project.readme_url].compact.to_json) %>"
                 onclick="event.preventDefault();JSON.parse(this.dataset.urls).forEach(u=>window.open(u,'_blank','noopener,noreferrer'))">open all</a>
            </dd>
          </dl>
        </div>

        <% if @ship.pending? %>
          <%= render "form", ship: @ship, can_review: can_review %>
        <% end %>

        <% if @ship.returned_by.present? || @ship.recert_reason.present? %>
          <div class="ship-review__return-alert">
            <h2 class="ship-review__return-alert-title">Returned from YSWS Review</h2>
            <% if @ship.returned_by.present? %>
              <p class="ship-review__return-alert-meta">by <%= @ship.returned_by.display_name %></p>
            <% end %>
            <% if @ship.recert_reason.present? %>
              <p class="ship-review__return-alert-reason"><%= @ship.recert_reason %></p>
            <% end %>
          </div>
        <% end %>

      </section>

      <aside class="ship-review__sidebar">
        <div class="ship-review__panel"
             data-controller="certification--ships--fraud-report"
             data-certification--ships--fraud-report-ship-id-value="<%= @ship.id %>">
          <h2 class="ship-review__panel-title">Actions</h2>
          <div class="ship-review__actions">
            <button class="action-btn action-btn--large action-btn--destructive"
                    data-action="click->certification--ships--fraud-report#toggle">
              Report to Fraud Squad
            </button>
            <div class="ship-review__fraud-form" hidden data-certification--ships--fraud-report-target="form">
              <textarea class="ship-review__fraud-form__input"
                        data-certification--ships--fraud-report-target="textarea"
                        placeholder="Why does this project look suspicious? (20 chars min)"
                        rows="4"></textarea>
              <div class="ship-review__fraud-form__footer">
                <button class="action-btn action-btn--small action-btn--destructive"
                        data-action="click->certification--ships--fraud-report#submit"
                        data-certification--ships--fraud-report-target="submitButton">
                  Send report
                </button>
                <button class="action-btn action-btn--small action-btn--secondary"
                        data-action="click->certification--ships--fraud-report#toggle">
                  Cancel
                </button>
              </div>
            </div>
            <% if @ship.pending? %>
              <% if can_review %>
                <button type="submit" form="unclaim-form-<%= @ship.id %>"
                        class="action-btn action-btn--large action-btn--destructive">
                  Unclaim review
                </button>
              <% else %>
                <%= button_to "Claim this review", admin_certification_ship_claim_path(@ship), method: :post,
                      class: "action-btn action-btn--large action-btn--primary" %>
              <% end %>
              <%= form_with url: set_project_type_admin_certification_ship_path(@ship), method: :patch do %>
                <%= select_tag :project_type,
                      options_for_select(
                        [["Unknown", nil, { disabled: true, hidden: @ship.project.project_type.present? }], *Project::AVAILABLE_CATEGORIES.map { |t| [t, t] }],
                        @ship.project.project_type
                      ),
                      onchange: "this.form.requestSubmit()",
                      class: "ship-queue__select" %>
              <% end %>
            <% end %>
          </div>
        </div>

        <% if @submitter_history %>
          <div class="ship-review__panel submitter-history">
            <h2 class="ship-review__panel-title">Submitter history</h2>
            <% if @submitter_history[:total] <= 1 %>
              <p class="ship-review__description">First submission from <%= @owner.display_name %>.</p>
            <% else %>
              <p class="submitter-history__summary">
                <%= pluralize(@submitter_history[:total], "review") %> across <%= pluralize(@submitter_history[:projects], "project") %>
                &middot; <%= @submitter_history[:approved] %> approved
                &middot; <%= @submitter_history[:returned] %> returned
              </p>
              <div class="submitter-history__cards">
                <% @submitter_history[:recent].each do |review| %>
                  <% current = review.id == @ship.id %>
                  <%= link_to admin_certification_ship_path(review), target: "_blank", rel: "noopener",
                        class: class_names("submitter-history__card", "submitter-history__card--current" => current) do %>
                    <div class="submitter-history__card-head">
                      <span class="status-pill status-pill--<%= review.status %>"><%= review.status.capitalize %></span>
                      <span class="submitter-history__card-id">#<%= review.id %></span>
                      <% if current %>
                        <span class="submitter-history__card-here">&larr; you're here</span>
                      <% end %>
                      <span class="submitter-history__card-date">
                        <%= review.decided_at ? l(review.decided_at.to_date, format: :short) : "—" %>
                      </span>
                    </div>
                    <div class="submitter-history__card-meta">
                      <%= review.project_with_deleted.title %>
                      <% if review.project_with_deleted.deleted? %>
                        <span class="submitter-history__card-deleted">(deleted)</span>
                      <% end %>
                      <% if review.returned? && review.returned_by %>
                        &middot; returned by <%= review.returned_by.display_name %>
                      <% elsif review.decided_at && review.reviewer %>
                        &middot; by <%= review.reviewer.display_name %>
                      <% end %>
                    </div>
                    <% if review.feedback.present? %>
                      <p class="submitter-history__card-feedback"><%= review.feedback %></p>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if !@ship.pending? %>
          <div class="ship-review__verdict-card">
            <h2 class="ship-review__panel-title">Verdict</h2>
            <div class="ship-review__verdict-outcome">
              <span class="status-pill status-pill--<%= @ship.status %>">
                <%= @ship.status.capitalize %>
              </span>
            </div>
            <% if @ship.feedback.present? %>
              <div class="ship-review__verdict-feedback">
                <h3>Feedback</h3>
                <p><%= @ship.feedback %></p>
              </div>
            <% end %>
            <% if @ship.verdict_video.attached? %>
              <div class="ship-review__verdict-video">
                <h3>Walkthrough Video</h3>
                <video controls playsinline class="ship-review__video-player">
                  <source src="<%= url_for(@ship.verdict_video) %>" type="<%= @ship.verdict_video.content_type %>">
                  Your browser does not support the video tag.
                </video>
              </div>
            <% end %>
            <div class="ship-review__verdict-actions">
              <%= link_to "Back to logs", logs_admin_certification_ships_path,
                    class: "action-btn action-btn--small action-btn--secondary" %>
              <%= link_to "Back to queue", admin_certification_ships_path,
                    class: "action-btn action-btn--small action-btn--secondary" %>
            </div>
          </div>
        <% end %>
      </aside>
    </div>
  </div>
</div>
