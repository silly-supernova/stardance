<%# Lapse timelapses for the project under review — mapped onto the shared
    recording gallery. `timelapses` is an array of Lapse API hashes (LapseService). %>
<% items = Array(timelapses).map do |tl|
     date = tl[:createdAt].present? ? l(Time.zone.at(tl[:createdAt].to_i / 1000).to_date, format: :short) : nil
     {
       video_url: tl[:playbackUrl],
       poster_url: tl[:thumbnailUrl],
       processing: tl[:visibility] == "FAILED_PROCESSING" ? "Processing failed" : "Still processing…",
       name: tl[:name].presence || "Untitled timelapse",
       sub: [ format_clock(tl[:duration]), date ].compact.join(" · ")
     }
   end %>
<%= render "recording_gallery",
      title: "Lapse timelapses",
      empty_text: "No Lapse timelapses found for this project.",
      items: items %>
