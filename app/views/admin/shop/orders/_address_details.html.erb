<div class="aorder__address-block">
  <div class="aorder__address-name">
    <%= address["first_name"] %> <%= address["last_name"] %>
  </div>

  <div class="aorder__address-lines">
    <%= address["line_1"] %><br>
    <% if address["line_2"].present? %>
      <%= address["line_2"] %><br>
    <% end %>
    <%= address["city"] %>, <%= address["state"] %> <%= address["postal_code"] %><br>
    <%= address["country"] %>
  </div>

  <% if user_email.present? || address["phone_number"].present? %>
    <div class="aorder__address-contacts">
      <% if user_email.present? %>
        <span>✉ <%= user_email %></span>
      <% end %>
      <% if address["phone_number"].present? %>
        <span>📞 <span class="sensitive"><%= address["phone_number"] %></span></span>
      <% end %>
    </div>
  <% end %>

  <div class="aorder__address-actions">
    <%
      full_address = [
        "#{address["first_name"]} #{address["last_name"]}",
        address["line_1"],
        address["line_2"].presence,
        "#{address["city"]}, #{address["state"]} #{address["postal_code"]}",
        address["country"]
      ].compact.join("\n")
    %>
    <button type="button" class="aorder__btn aorder__btn--secondary aorder__copy-btn"
            data-copy="<%= full_address %>"
            aria-label="Copy full address">
      📋 Copy address
    </button>
    <% if user_email.present? %>
      <button type="button" class="aorder__btn aorder__btn--secondary aorder__copy-btn"
              data-copy="<%= user_email %>"
              aria-label="Copy email">
        ✉ Copy email
      </button>
    <% end %>
  </div>

  <div class="aorder__address-security">
    🔒 Address access has been logged for security purposes.
  </div>
</div>

<script>
  document.querySelectorAll('.aorder__copy-btn').forEach(function(btn) {
    var original = btn.innerHTML;
    btn.addEventListener('click', function() {
      navigator.clipboard.writeText(this.dataset.copy).then(function() {
        btn.textContent = '✓ Copied';
        setTimeout(function() { btn.innerHTML = original; }, 1500);
      });
    });
  });
</script>
