<% @feed_posts.each_with_index do |post, index| %>
  <% if post.postable_type == "Post::ShipEvent" %>
    <%= render "projects/ship_card", post: post, project: post.project %>
  <% else %>
    <%= render Posts::CardComponent.new(post: post, current_user: current_user) %>
  <% end %>

  <% if @pagy.page == 1 && index.zero? && @recommended_projects&.any? %>
    <%= render Feed::ShelfComponent.new(
          title: "Recommended projects",
          items: @recommended_projects
        ) do |shelf| %>
      <% @recommended_projects.each do |project| %>
        <% shelf.with_item do %>
          <%= render Projects::ShelfCardComponent.new(project: project) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<% if @feed_posts.empty? && @pagy.page == 1 && @pagy.next.nil? %>
  <% if @recommended_projects&.any? %>
    <%= render Feed::ShelfComponent.new(
          title: "Recommended projects",
          items: @recommended_projects
        ) do |shelf| %>
      <% @recommended_projects.each do |project| %>
        <% shelf.with_item do %>
          <%= render Projects::ShelfCardComponent.new(project: project) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <p class="feed-home__empty">Nothing here yet. Post a devlog or ship your project to start the feed.</p>
<% end %>

<% if @pagy.next %>
  <%= turbo_frame_tag "home_feed_page_#{@pagy.next}",
                      src: home_feed_path(page: @pagy.next),
                      loading: :lazy,
                      target: "_top",
                      class: "feed-home__frame" do %>
    <div class="feed-loading" role="status" aria-live="polite">
      <span class="feed-loading__spinner" aria-hidden="true"></span>
      <span class="feed-loading__label">Loading more&hellip;</span>
    </div>
  <% end %>
<% end %>
