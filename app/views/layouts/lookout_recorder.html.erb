<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? "#{strip_tags(yield(:title))} - Stardance" : "Record a timelapse - Stardance" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="lookout-recorder-body">
    <%= yield %>
  </body>
</html>
