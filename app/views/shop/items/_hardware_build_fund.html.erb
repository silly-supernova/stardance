<div class="shop-item-card"
     data-regions="<%= Shop::Regionalizable::REGION_CODES.join(',') %>"
     data-price="0"
     data-categories=""
     data-achievement-locked="false">
  <div class="shop-item-card__image-wrap">
    <%= image_tag "shop/hardware_build_fund.png", alt: "Hardware Build Fund", class: "shop-item-card__image", loading: "lazy" %>
    <span class="shop-item-card__ribbon shop-item-card__ribbon--new">Coming soon</span>
  </div>
  <div class="shop-item-card__body">
    <h3 class="shop-item-card__title">Hardware Build Fund</h3>
    <div class="shop-item-card__description">We'll fund whatever hardware project you build!</div>
<%= render ActionButtonComponent.new(
          text: "Coming soon",
          size: :large,
          variant: :primary,
          class: "shop-item-card__order-cta",
          disabled: true
        ) %>
  </div>
</div>
