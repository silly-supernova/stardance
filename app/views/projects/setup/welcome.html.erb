<% content_for :title, "Welcome to your new project" %>
<main class="onboarding-screen onboarding-screen--complete onboarding-screen--project-welcome project-setup-screen"
      data-controller="onboarding-transition">
  <div class="onboarding-complete__background" aria-hidden="true">
    <video class="onboarding-complete__video" autoplay muted loop playsinline preload="auto">
      <source src="<%= asset_path("stardance-bg.webm") %>" type="video/webm">
    </video>
    <%= image_tag image_path("landing/space/moon.png"), class: "onboarding-complete__planet", alt: "" %>
  </div>

  <div class="onboarding-complete__content">
    <%= image_tag image_url("landing/done-before/star-artwork.png"),
                  class: "onboarding-complete__mascots",
                  alt: "",
                  aria: { hidden: true } %>

    <h1 class="onboarding-complete__title">
      Welcome to your new project.
    </h1>
    <p class="onboarding-complete__subtitle">
      <em><%= @setup_project.title %></em> is ready and waiting for you.
      <br>You're in the running for free stickers and the <a href="<%= raffle_base_url %>/" style="color: inherit; text-decoration: underline;">GPU raffle</a>.
    </p>

    <%= render SpecialActionButtonComponent.new(
          text: "Open my project",
          href: project_path(@setup_project, welcome: 1),
          class: "onboarding-complete__continue",
          data: { action: "click->onboarding-transition#leave" }
        ) %>
  </div>
</main>
