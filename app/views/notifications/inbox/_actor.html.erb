<%# The notification's actor as a profile link, or a fallback label when the
    actor is missing (e.g. a deleted account). Pass `fallback:` to override. %>
<% if notification.actor %>
  <%= link_to "@#{notification.actor.display_name}", user_path(notification.actor), class: "notifications-item__actor" %>
<% else %>
  <span class="notifications-item__actor"><%= local_assigns.fetch(:fallback, "Someone") %></span>
<% end %>
