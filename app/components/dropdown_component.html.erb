<div class="dropdown dropdown--<%= color %>">
  <% if label.present? %>
    <label class="dropdown__label"><%= label %></label>
  <% end %>
  <select class="dropdown__select"
          data-filter-type="<%= label %>"
          <% if action %> data-action="<%= action %>"<% end %>>
    <% options.each do |option| %>
      <% if option.is_a?(Hash) %>
        <option value="<%= option[:value] %>" <%= "selected" if option[:value].to_s == selected_value.to_s %>><%= option[:label] %></option>
      <% else %>
        <option value="<%= option %>" <%= "selected" if option.to_s == selected_value.to_s %>><%= option %></option>
      <% end %>
    <% end %>
  </select>
</div>
